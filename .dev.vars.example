# Cloudflare Wrangler 本地运行时读取这个文件。
# 复制为 `.dev.vars` 后即可执行 `npm run worker:dev` 或 `npm run preview`。

OPENROUTER_API_KEY=your_openrouter_api_key
# Lemon Squeezy API key / Store ID / Variant ID / webhook secret
LEMON_SQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMON_SQUEEZY_STORE_ID=your_store_id
LEMON_SQUEEZY_VARIANT_ID=your_variant_id
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret
# 对应线上站点域名，本地联调可先保持 127.0.0.1:8787
PUBLIC_APP_URL=http://127.0.0.1:8787
